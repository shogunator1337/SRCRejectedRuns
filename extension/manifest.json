{
  "manifest_version": 3,
  "name": "Speedrun.com Rejected Runs",
  "version": "1.0",
  "description": "Показывает отклоненные раны (rejected runs) для игр на speedrun.com",
  "browser_specific_settings": {
    "gecko": {
      "id": "rejected-runs@speedrun.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "scripting"
  ],
  "host_permissions": [
    "https://www.speedrun.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.speedrun.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
